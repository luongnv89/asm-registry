{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/luongnv89/asm-registry/main/schema/manifest.v1.json",
  "title": "ASM Registry Manifest v1",
  "description": "Schema for a published skill manifest in the asm-registry",
  "type": "object",
  "required": [
    "name",
    "author",
    "description",
    "repository",
    "commit",
    "security_verdict",
    "published_at"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Bare skill name, lowercase, alphanumeric and hyphens only",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "minLength": 1,
      "maxLength": 128
    },
    "author": {
      "type": "string",
      "description": "GitHub username of the publisher",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "minLength": 1,
      "maxLength": 39
    },
    "description": {
      "type": "string",
      "description": "One-line description of the skill",
      "minLength": 1,
      "maxLength": 256
    },
    "repository": {
      "type": "string",
      "description": "Full GitHub URL of the skill repository",
      "pattern": "^https://github\\.com/[a-zA-Z0-9_-]+/[a-zA-Z0-9._-]+$"
    },
    "commit": {
      "type": "string",
      "description": "Pinned commit SHA at publish time",
      "pattern": "^[0-9a-f]{40}$"
    },
    "skill_path": {
      "type": "string",
      "description": "Relative path from the repository root to the skill directory (for multi-skill repos)",
      "minLength": 1,
      "maxLength": 256
    },
    "version": {
      "type": "string",
      "description": "Semantic version if available",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier",
      "maxLength": 64
    },
    "tags": {
      "type": "array",
      "description": "Category tags for discovery",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "maxLength": 32
      },
      "maxItems": 10,
      "uniqueItems": true
    },
    "security_verdict": {
      "type": "string",
      "description": "Security audit result at publish time",
      "enum": [
        "pass",
        "warning",
        "dangerous"
      ]
    },
    "published_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the skill was published",
      "format": "date-time"
    },
    "checksum": {
      "type": "string",
      "description": "Reserved for future content-addressed installs",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
